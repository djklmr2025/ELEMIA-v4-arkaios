{
  "version": 2,
  "rewrites": [
    {
      "source": "/authorize",
      "destination": "/api/authorize.js"
    },
    {
      "source": "/token",
      "destination": "/api/token.js"
    },
    {
      "source": "/.well-known/oauth-authorization-server",
      "destination": "/api/oauth-metadata.js"
    },
    {
      "source": "/.well-known/oauth-authorization-server/mcp",
      "destination": "/api/oauth-metadata.js"
    },
    {
      "source": "/.well-known/oauth-protected-resource",
      "destination": "/api/oauth-protected-resource.js"
    },
    {
      "source": "/.well-known/oauth-protected-resource/mcp",
      "destination": "/api/oauth-protected-resource.js"
    },
    {
      "source": "/mcp",
      "destination": "/api/index.mjs"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.mjs"
    }
  ]
}
